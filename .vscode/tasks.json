{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bicep: Validate DEV",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "${workspaceFolder}/scripts/validate.ps1", "-Environment", "dev"],
      "group": "test",
      "presentation": { "reveal": "always", "panel": "new" }
    },
    {
      "label": "Bicep: Deploy DEV",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "${workspaceFolder}/scripts/deploy.ps1", "-Environment", "dev"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "new" }
    },
    {
      "label": "Bicep: Deploy PROD",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "${workspaceFolder}/scripts/deploy.ps1", "-Environment", "prod"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "new" }
    },
    {
      "label": "Bicep: What-If DEV",
      "type": "shell",
      "command": "pwsh",
      "args": ["-File", "${workspaceFolder}/scripts/deploy.ps1", "-Environment", "dev", "-WhatIf"],
      "group": "build",
      "presentation": { "reveal": "always", "panel": "new" }
    }
  ]
}